generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ai_chat_history {
  id          String   @id
  user_id     String
  session_id  String
  messages    Json
  context     String?
  tokens_used Int
  created_at  DateTime @default(now())
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model announcements {
  id              String     @id
  title           String
  content         String
  target_branches String[]
  target_years    Int[]
  target_roles    UserRole[]
  is_active       Boolean    @default(true)
  priority        Priority   @default(MEDIUM)
  attachment_url  String?
  created_by      String
  created_at      DateTime   @default(now())
  updated_at      DateTime
  expires_at      DateTime?
}

model bookings {
  id                String          @id
  student_id        String
  mentor_id         String
  mentor_session_id String
  scheduled_at      DateTime
  duration_minutes  Int
  price             Decimal         @db.Decimal(6, 2)
  status            BookingStatus   @default(PENDING)
  payment_id        String?         @unique
  meeting_link      String?
  cancel_reason     String?
  created_at        DateTime        @default(now())
  updated_at        DateTime
  mentors           mentors         @relation(fields: [mentor_id], references: [id], onDelete: Cascade)
  mentor_sessions   mentor_sessions @relation(fields: [mentor_session_id], references: [id], onDelete: Cascade)
  users             users           @relation(fields: [student_id], references: [id], onDelete: Cascade)
  payments          payments?
}

model chat_messages {
  id             String      @id
  room_id        String
  sender_id      String
  content        String
  message_type   MessageType @default(TEXT)
  attachment_url String?
  is_edited      Boolean     @default(false)
  edited_at      DateTime?
  created_at     DateTime    @default(now())
  chat_rooms     chat_rooms  @relation(fields: [room_id], references: [id], onDelete: Cascade)
  users          users       @relation(fields: [sender_id], references: [id], onDelete: Cascade)
}

model chat_rooms {
  id              String          @id
  name            String
  type            RoomType        @default(GENERAL)
  branch          String?
  year            Int?
  session_id      String?
  is_active       Boolean         @default(true)
  participant_ids String[]
  created_by      String
  created_at      DateTime        @default(now())
  chat_messages   chat_messages[]
}

model mentor_sessions {
  id               String      @id
  mentor_id        String
  title            String
  description      String
  duration_minutes Int
  price            Decimal     @db.Decimal(6, 2)
  session_type     SessionType @default(ONE_ON_ONE)
  max_participants Int         @default(1)
  tags             String[]
  is_active        Boolean     @default(true)
  created_at       DateTime    @default(now())
  updated_at       DateTime
  bookings         bookings[]
  mentors          mentors     @relation(fields: [mentor_id], references: [id], onDelete: Cascade)
}

model mentors {
  id              String            @id
  user_id         String            @unique
  approved        Boolean           @default(false)
  approved_at     DateTime?
  approval_notes  String?
  rating          Decimal           @default(0.00) @db.Decimal(3, 2)
  total_sessions  Int               @default(0)
  total_earnings  Decimal           @default(0.00) @db.Decimal(10, 2)
  resume_url      String?
  expertise_areas String[]
  hourly_rate     Decimal           @db.Decimal(6, 2)
  is_available    Boolean           @default(true)
  created_at      DateTime          @default(now())
  updated_at      DateTime
  bookings        bookings[]
  mentor_sessions mentor_sessions[]
  users           users             @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model notes {
  id             String   @id
  title          String
  description    String
  subject        String
  branch         String?
  semester       Int?
  unit           Int?
  file_url       String
  file_size      BigInt
  file_type      String
  uploaded_by    String
  is_public      Boolean  @default(true)
  download_count Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime
  users          users    @relation(fields: [uploaded_by], references: [id], onDelete: Cascade)
}

model payments {
  id                  String        @id
  user_id             String
  booking_id          String?       @unique
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("INR")
  status              PaymentStatus @default(PENDING)
  payment_method      PaymentMethod @default(RAZORPAY)
  razorpay_order_id   String?
  razorpay_payment_id String?
  refund_id           String?
  created_at          DateTime      @default(now())
  updated_at          DateTime
  bookings            bookings?     @relation(fields: [booking_id], references: [id])
  users               users         @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model results_snapshots {
  id         String        @id
  student_id String
  usn        String
  semester   Int
  data       Json
  source     ResultsSource @default(MANUAL_ENTRY)
  scraped_at DateTime?
  created_at DateTime      @default(now())
  updated_at DateTime
  users      users         @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model user_profiles {
  id            String   @id @default(cuid())
  user_id       String   @unique
  first_name    String
  last_name     String
  phone         String?
  branch        String?
  year          Int?
  semester      Int?
  avatar_url    String?
  bio           String?
  voice_enabled Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model users {
  id                String              @id @default(cuid())
  email             String              @unique
  usn               String?             @unique
  password_hash     String
  role              UserRole            @default(STUDENT)
  email_verified    Boolean             @default(false)
  is_active         Boolean             @default(true)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @default(now())
  last_login        DateTime?
  ai_chat_history   ai_chat_history[]
  bookings          bookings[]
  chat_messages     chat_messages[]
  mentors           mentors?
  notes             notes[]
  payments          payments[]
  resources         resources[]
  results_snapshots results_snapshots[]
  user_profiles     user_profiles?
  user_settings     user_settings?

  // Gamification relations
  user_progress     user_progress?
  user_streak       user_streak?
  user_achievements user_achievement[]
  user_avatars      user_avatar[]
  user_missions     user_mission[]
  user_rewards      user_reward[]
  user_activities   user_activity_log[]
  notifications     notification[]
  leaderboard_entries leaderboard_entry[]
}

model user_settings {
  id                         String   @id @default(cuid())
  user_id                    String   @unique
  email_notifications        Boolean  @default(true)
  push_notifications         Boolean  @default(false)
  announcement_notifications Boolean  @default(true)
  assignment_notifications   Boolean  @default(true)
  theme                      String   @default("light")
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt
  users                      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model platform_settings {
  id                    String   @id @default("global")
  platform_name         String   @default("LearnWave")
  platform_description  String   @default("AI-Powered Academic Support Platform")
  maintenance_mode      Boolean  @default(false)
  ai_assistant_enabled  Boolean  @default(true)
  forum_enabled         Boolean  @default(true)
  resources_enabled     Boolean  @default(true)
  mentorship_enabled    Boolean  @default(true)
  announcements_enabled Boolean  @default(true)
  updated_at            DateTime @updatedAt
}

model resources {
  id              String            @id @default(cuid())
  title           String
  description     String?
  uploaded_by     String
  created_at      DateTime          @default(now())
  fileName        String
  fileSize        Int
  fileUrl         String
  semester        Int
  subject         String
  type            String
  unit            String?
  processed       Boolean           @default(false)
  branch          String?
  downloadCount   Int               @default(0)
  is_model_paper  Boolean           @default(false)
  module_number   Int?
  scheme          String?
  is_approved     Boolean           @default(false)
  is_library      Boolean           @default(false)
  document_chunks document_chunks[]
  users           users             @relation(fields: [uploaded_by], references: [id], onDelete: Cascade)
}

model document_chunks {
  id          String    @id @default(cuid())
  resource_id String
  page_number Int
  chunk_index Int
  content     String
  token_count Int
  created_at  DateTime  @default(now())
  resources   resources @relation(fields: [resource_id], references: [id], onDelete: Cascade)

  @@index([resource_id])
  @@index([resource_id, page_number])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum PaymentMethod {
  RAZORPAY
  WALLET
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ResultsSource {
  MANUAL_ENTRY
  SCRAPED
  IMPORTED
}

enum RoomType {
  BRANCH
  YEAR
  GENERAL
  PLACEMENT
  SESSION
}

enum SessionType {
  ONE_ON_ONE
  GROUP
  WEBINAR
}

enum UserRole {
  STUDENT
  MENTOR
  ADMIN
}

model user_progress {
  id                String   @id @default(cuid())
  user_id           String   @unique
  xp                Int      @default(0)
  level             Int      @default(1)
  total_xp_earned   Int      @default(0)
  updated_at        DateTime @updatedAt
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model user_streak {
  id                String   @id @default(cuid())
  user_id           String   @unique
  current_streak    Int      @default(0)
  best_streak       Int      @default(0)
  last_login_date   DateTime?
  streak_freezes    Int      @default(0)
  updated_at        DateTime @updatedAt
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model achievement {
  id                String            @id @default(cuid())
  title             String
  description       String
  icon              String?
  type              AchievementType
  requirement_value Int
  rarity            Rarity            @default(COMMON)
  created_at        DateTime          @default(now())
  user_achievements user_achievement[]
}

model user_achievement {
  id                String      @id @default(cuid())
  user_id           String
  achievement_id    String
  unlocked_at       DateTime    @default(now())
  users             users       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  achievements      achievement @relation(fields: [achievement_id], references: [id], onDelete: Cascade)

  @@unique([user_id, achievement_id])
}

model avatar {
  id                String            @id @default(cuid())
  name              String
  image_url         String
  rarity            Rarity            @default(COMMON)
  unlock_type       AvatarUnlockType
  unlock_value      Int
  created_at        DateTime          @default(now())
  user_avatars      user_avatar[]
}

model user_avatar {
  id                String   @id @default(cuid())
  user_id           String
  avatar_id         String
  unlocked_at       DateTime @default(now())
  equipped          Boolean  @default(false)
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  avatars           avatar   @relation(fields: [avatar_id], references: [id], onDelete: Cascade)

  @@unique([user_id, avatar_id])
}

model mission {
  id                String         @id @default(cuid())
  title             String
  description       String?
  xp_reward         Int
  type              MissionType    @default(DAILY)
  action_type       ActionType
  target_value      Int
  active_from       DateTime?
  active_to         DateTime?
  created_at        DateTime       @default(now())
  user_missions     user_mission[]
}

model user_mission {
  id                String   @id @default(cuid())
  user_id           String
  mission_id        String
  progress          Int      @default(0)
  completed         Boolean  @default(false)
  updated_at        DateTime @updatedAt
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  missions          mission  @relation(fields: [mission_id], references: [id], onDelete: Cascade)

  @@unique([user_id, mission_id])
}

model leaderboard_entry {
  id                String   @id @default(cuid())
  user_id           String
  xp                Int
  rank              Int
  month             Int
  year              Int
  created_at        DateTime @default(now())
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, month, year])
}

model reward {
  id                String        @id @default(cuid())
  name              String
  description       String?
  cost_xp           Int
  reward_type       RewardType
  created_at        DateTime      @default(now())
  user_rewards      user_reward[]
}

model user_reward {
  id                String       @id @default(cuid())
  user_id           String
  reward_id         String
  redeemed_at       DateTime     @default(now())
  status            String       @default("PENDING") // PENDING, USED
  users             users        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  rewards           reward       @relation(fields: [reward_id], references: [id], onDelete: Cascade)
}

model user_activity_log {
  id                String     @id @default(cuid())
  user_id           String
  action_type       ActionType
  meta_data         Json?
  created_at        DateTime   @default(now())
  users             users      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model notification {
  id                String   @id @default(cuid())
  user_id           String
  message           String
  type              String   @default("INFO")
  is_read           Boolean  @default(false)
  created_at        DateTime @default(now())
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

enum AchievementType {
  QUIZ
  STREAK
  FORUM
  ASSIGNMENT
  LEVEL
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum AvatarUnlockType {
  XP
  LEVEL
  STREAK
  LEADERBOARD
  ADMIN
}

enum MissionType {
  DAILY
  WEEKLY
}

enum ActionType {
  LOGIN
  QUIZ_COMPLETED
  WATCH_VIDEO
  FORUM_POST
  ANSWER_ACCEPTED
  ASSIGNMENT_SUBMITTED
}

enum RewardType {
  AI_TIME
  DISCOUNT
  PREMIUM_THEME
  SESSION_MINUTES
}
